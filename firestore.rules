rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'emadavlhi6@gmail.com' && request.auth.token.email_verified == true
      );
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'money', 'ownedSkins', 'currentSkin']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.money is int && data.money >= 0 &&
             (!('rp' in data) || (data.rp is int && data.rp >= 0)) &&
             (!('claimedRewards' in data) || (data.claimedRewards is list && data.claimedRewards.size() <= 100)) &&
             data.ownedSkins is list && data.ownedSkins.size() <= 100 &&
             data.currentSkin is string && data.currentSkin.size() <= 64 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000000))) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('highScore' in data) || (data.highScore is int && data.highScore >= 0)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // --- Score Validation ---
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'name', 'score', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 64 &&
             data.score is int && data.score >= 0 &&
             data.timestamp == request.time;
    }

    // --- Skin Validation ---
    function isValidSkin(data) {
      return data.keys().hasAll(['name', 'price', 'type', 'value']) &&
             data.name is string && data.name.size() <= 64 &&
             data.price is int && data.price >= 0 &&
             data.type in ['color', 'pattern'] &&
             data.value is string && data.value.size() <= 2000;
    }

    // --- Routes ---

    match /skins/{skinId} {
      allow list, get: if true; // Publicly available skins
      allow create: if isSignedIn() && isValidSkin(incoming());
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true; // Allow public view for leaderboards
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().uid == userId;
      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      (
                        // Action: Update Stats/Profile
                        incoming().diff(existing()).affectedKeys().hasOnly(['money', 'ownedSkins', 'currentSkin', 'highScore', 'updatedAt', 'displayName', 'photoURL', 'rp', 'claimedRewards'])
                      );
    }

    match /scores/{scoreId} {
      allow list: if true;
      allow get: if true;

      allow create: if isSignedIn() && 
                      isValidScore(incoming());
      
      // Scores are immutable
      allow update, delete: if false;
    }

    match /dailyScores/{scoreId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidScore(incoming());
      allow delete: if isSignedIn(); // Allow clearing for reset
    }

    match /system/globals {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
