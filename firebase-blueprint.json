{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user statistics, balance, and owned skins.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "money": { "type": "integer" },
        "rp": { "type": "integer", "description": "Rank Points" },
        "claimedRewards": { "type": "array", "items": { "type": "integer" } },
        "ownedSkins": { "type": "array", "items": { "type": "string" } },
        "currentSkin": { "type": "string" },
        "highScore": { "type": "integer" },
        "missions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "desc": { "type": "string" },
              "rp": { "type": "integer" },
              "goal": { "type": "integer" },
              "current": { "type": "integer" },
              "isClaimed": { "type": "boolean" },
              "type": { "type": "string", "enum": ["score", "kill", "match"] }
            }
          }
        },
        "lastMissionReset": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "money", "ownedSkins", "currentSkin"]
    },
    "Score": {
      "title": "Score Entry",
      "description": "A record of a high score achieved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "score", "timestamp"]
    },
    "Skin": {
      "title": "Custom Skin",
      "description": "Custom skin created by admin.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "integer" },
        "type": { "type": "string", "enum": ["color", "pattern", "head"] },
        "value": { "type": "string" },
        "isEvent": { "type": "boolean" }
      },
      "required": ["name", "price", "type", "value"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "scores/{scoreId}": {
      "schema": "Score",
      "description": "Global high scores"
    },
    "skins/{skinId}": {
      "schema": "Skin",
      "description": "Custom snake skins"
    },
    "dailyScores/{scoreId}": {
      "schema": "Score",
      "description": "Daily reset leaderboard scores"
    },
    "system/globals": {
      "schema": {
        "type": "object",
        "properties": {
          "nextResetAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Global system state"
    }
  }
}
